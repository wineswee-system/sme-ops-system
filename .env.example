# ── Supabase (必填) ──
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Google Gemini AI (AI 助手功能) ──
# ⚠️  SERVER-SIDE ONLY — set via `supabase secrets set GEMINI_API_KEY=...`
# Do NOT use VITE_ prefix — that would bake the key into the client bundle.
# GEMINI_API_KEY=your_gemini_api_key_here

# ── LINE 整合 ──
# 每個 LIFF 頁面可使用獨立 LIFF ID。未設定時退回 VITE_LIFF_ID。
VITE_LIFF_ID=your_default_liff_id                  # 預設後備
VITE_LIFF_CLOCK_ID=your_liff_clock_id              # /liff/clock 打卡頁
VITE_LIFF_TASK_ID=your_liff_task_id                # /liff/task 任務頁
VITE_LIFF_DASHBOARD_ID=your_liff_dashboard_id      # /liff/dashboard 儀錶板
VITE_LINE_CHANNEL_TOKEN=your_line_channel_token
VITE_LINE_CHANNEL_SECRET=your_line_channel_secret

# ── LINE Edge Function secrets (set via `supabase secrets set`, NOT VITE_) ──
# LIFF_TASK_ID=your_liff_task_id              # opens /liff/task
# LIFF_NEW_TASK_ID=your_liff_new_task_id      # opens new-task LIFF
# LIFF_DASHBOARD_ID=your_liff_dashboard_id    # opens /liff/dashboard (📊 儀錶板 button in /說明)

# ══════════════════════════════════════════════════════════════════
# ⚠️  SECURITY WARNING — 以下金流 / 簡訊 / 郵件變數
# 所有 VITE_ 前綴變數會被 Vite 打包進「公開的前端 bundle」，
# 任何人開 DevTools 都看得到。
# 金流簽章密鑰（LINE Pay ChannelSecret、ECPay HashKey/HashIV）、
# SMS API key、SMTP 帳密 MUST live server-side —
# 正式環境請放 Supabase Edge Function secrets（`supabase secrets set ...`），
# 絕不可放進 VITE_ 變數。
# 這些 placeholder 只為 legacy client-side stub（src/lib/paymentGateway.js）
# 而保留；請勿在此填入真實密鑰。
# ══════════════════════════════════════════════════════════════════

# ── LINE Pay ──
VITE_LINEPAY_CHANNEL_ID=your_linepay_channel_id
# ⚠️ 簽章密鑰：正式環境必須放 Edge Function secrets，不可用 VITE_（會進公開 bundle）
VITE_LINEPAY_CHANNEL_SECRET=your_linepay_channel_secret

# ── ECPay 金流 ──
VITE_ECPAY_MERCHANT_ID=your_ecpay_merchant_id
# ⚠️ HashKey/HashIV 是簽章密鑰：正式環境必須放 Edge Function secrets，不可用 VITE_
VITE_ECPAY_HASH_KEY=your_ecpay_hash_key
VITE_ECPAY_HASH_IV=your_ecpay_hash_iv

# ── 簡訊 ──
# ⚠️ API key 會進公開 bundle：正式環境必須放 Edge Function secrets
VITE_SMS_API_KEY=your_sms_api_key

# ── SMTP 郵件 ──
# ⚠️ SMTP 設定（尤其帳號）會進公開 bundle：正式環境必須改由 Edge Function 寄信
VITE_SMTP_HOST=smtp.example.com
VITE_SMTP_PORT=587
VITE_SMTP_USER=your_smtp_user

# ── 電商串接 ──
VITE_ECOMMERCE_API=your_ecommerce_api_url
